<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <HorizontalScrollView
        android:id="@+id/extra_keys_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1A1A1A"
        android:scrollbars="none">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">
            
            <Button android:id="@+id/btn_esc" android:layout_width="wrap_content" android:layout_height="40dp" android:text="ESC" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="55dp"/>
            <Button android:id="@+id/btn_ctrl" android:layout_width="wrap_content" android:layout_height="40dp" android:text="CTRL" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="60dp"/>
            <Button android:id="@+id/btn_alt" android:layout_width="wrap_content" android:layout_height="40dp" android:text="ALT" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="55dp"/>
            <Button android:id="@+id/btn_tab" android:layout_width="wrap_content" android:layout_height="40dp" android:text="TAB" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="55dp"/>
            <Button android:id="@+id/btn_dash" android:layout_width="wrap_content" android:layout_height="40dp" android:text="-" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="45dp"/>
            <Button android:id="@+id/btn_slash" android:layout_width="wrap_content" android:layout_height="40dp" android:text="/" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="8dp" android:minWidth="45dp"/>
            
            <Button android:id="@+id/btn_left" android:layout_width="wrap_content" android:layout_height="40dp" android:text="←" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="45dp"/>
            <Button android:id="@+id/btn_down" android:layout_width="wrap_content" android:layout_height="40dp" android:text="↓" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="45dp"/>
            <Button android:id="@+id/btn_up" android:layout_width="wrap_content" android:layout_height="40dp" android:text="↑" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:layout_marginEnd="4dp" android:minWidth="45dp"/>
            <Button android:id="@+id/btn_right" android:layout_width="wrap_content" android:layout_height="40dp" android:text="→" android:backgroundTint="#333333" android:textColor="#FFFFFF" android:minWidth="45dp"/>
            
        </LinearLayout>
    </HorizontalScrollView>

    <WebView
        android:id="@+id/webview_terminal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/extra_keys_scroll" />

    <EditText
        android:id="@+id/hidden_input"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_alignParentTop="true"
        android:background="@null"
        android:textColor="#00000000"
        android:cursorVisible="false"
        android:inputType="textVisiblePassword|textNoSuggestions"
        android:imeOptions="actionDone" />

</RelativeLayout>
